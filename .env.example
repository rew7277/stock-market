# ─── Kite Connect API Credentials ───────────────────────────────────────────
# Get from https://developers.kite.trade/apps
KITE_API_KEY=your_api_key_here
KITE_API_SECRET=your_api_secret_here

# ─── Trading Capital ─────────────────────────────────────────────────────────
CAPITAL=100000

# ─── CORS Origins (comma-separated, use * for open access) ──────────────────
# Production: set to your Railway domain, e.g. https://algotrade.up.railway.app
CORS_ORIGINS=*

# ─── Database Path (Railway: /tmp/ is writable, /data/ needs a volume) ───────
# Leave empty to use default: /tmp/algotrade_ultimate.db
# DB_PATH=/tmp/algotrade_ultimate.db

# ─── Kite Redirect URL ────────────────────────────────────────────────────────
# Must match EXACTLY what's in your Kite Developer Console app settings.
# Local:   http://127.0.0.1:8000/callback
# Railway: https://YOUR-APP.up.railway.app/callback
KITE_REDIRECT_URL=http://127.0.0.1:8000/callback
